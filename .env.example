# Application Environment
APP_ENV=development

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MQTT Broker Configuration
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=knocklock-api

# MQTT Topic Configuration
MQTT_TOPIC_PREFIX=knocklock/v1/devices

# Redis Key Configuration
EVENT_STREAM_KEY=knocklock:events
DEVICE_STATE_KEY_PREFIX=knocklock:device_state:

# Logging
LOG_LEVEL=INFO
